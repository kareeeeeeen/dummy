# Copy to .env.local — NEVER commit .env.local
# Also add ALL of these in Vercel → Settings → Environment Variables

# ---- Supabase (Settings → API in your Supabase dashboard) ----
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only. Bypasses RLS. Never expose with NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- Gemini (aistudio.google.com → Get API key) ----
GEMINI_API_KEY=AIza...

# ---- Fonnte (fonnte.com dashboard → device token) ----
FONNTE_TOKEN=xxxx

# ---- App behavior ----
# 'sim' = self-contained demo, no backend needed (safe default)
# 'live' = real Supabase + WhatsApp + Gemini pipeline
NEXT_PUBLIC_DEFAULT_MODE=sim
# Cap outbound WA per blast so you never accidentally spam (demo: your team's numbers only)
BLAST_MAX_RECIPIENTS=10
